---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MediaStrip from '../../components/MediaStrip.astro';
import ReportContent from '../../components/ReportContent.astro';

export async function getStaticPaths() {
  const reports = await getCollection('reports');
  return reports.map((report) => ({
    params: { slug: report.slug },
    props: { report },
  }));
}

const { report } = Astro.props;
const { Content } = await report.render();
---

<BaseLayout
  title={`${report.data.title} - 鬼哥的 AI 行业每日简报`}
  description={report.data.description}
  wide
>
  <div class="mb-4">
    <a href="/fin-report/archive" class="text-sm text-blue-600 hover:text-blue-700">
      &larr; 返回归档
    </a>
  </div>

  <article>
    <header class="mb-2">
      <time class="text-sm font-medium text-blue-600">{report.data.dateStr}</time>
      <h1 class="mt-1 text-2xl font-bold text-gray-900">{report.data.title}</h1>
    </header>

    <MediaStrip
      infographic={report.data.infographic}
      title={report.data.title}
      hasSlides={report.data.hasSlides}
      slideCount={report.data.slideCount}
      dateStr={report.data.dateStr}
    />

    <ReportContent>
      <Content />
    </ReportContent>
  </article>
</BaseLayout>
