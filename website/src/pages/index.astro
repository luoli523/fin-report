---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectorSection from '../components/SectorSection.astro';
import SubscribeForm from '../components/SubscribeForm.astro';

const SECTORS: { key: string; label: string; icon: string; filter: (r: CollectionEntry<'reports'>) => boolean }[] = [
  { key: 'ai', label: 'AI 行业', icon: '🤖', filter: (_r) => true },
];

const allReports = (await getCollection('reports'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="鬼哥的 AI 行业每日简报" description="每日自动生成的 AI 行业金融分析与投资简报">
  {SECTORS.map((sector) => {
    const sectorReports = allReports.filter(sector.filter);
    return (
      <SectorSection
        label={sector.label}
        icon={sector.icon}
        sectorKey={sector.key}
        reports={sectorReports}
      />
    );
  })}

  <SubscribeForm />
</BaseLayout>
