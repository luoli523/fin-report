---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import InfographicViewer from '../../../components/InfographicViewer.astro';
import SlideGallery from '../../../components/SlideGallery.astro';
import { t, getBasePath } from '../../../i18n/ui';

const lang = 'en';
const base = getBasePath(lang);

export async function getStaticPaths() {
  const reports = await getCollection('reports');
  return reports.map((report) => ({
    params: { slug: report.slug },
    props: { report },
  }));
}

const { report } = Astro.props;
const { Content } = await report.render();
---

<BaseLayout
  title={`${report.data.title} - ${t(lang, 'site.title')}`}
  description={report.data.description}
  lang={lang}
>
  <div class="mb-6">
    <a href={`${base}/archive`} class="text-sm text-blue-600 hover:text-blue-700">
      &larr; {t(lang, 'report.backToArchive')}
    </a>
  </div>

  <article>
    <header class="mb-8">
      <time class="text-sm font-medium text-blue-600">{report.data.dateStr}</time>
      <h1 class="mt-1 text-2xl font-bold text-gray-900">{report.data.title}</h1>
    </header>

    {report.data.infographic && (
      <InfographicViewer src={report.data.infographic} alt={report.data.title} />
    )}

    {report.data.hasSlides && report.data.slideCount > 0 && (
      <SlideGallery dateStr={report.data.dateStr} count={report.data.slideCount} lang={lang} />
    )}

    <div class="prose prose-gray prose-lg max-w-none mt-8">
      <Content />
    </div>
  </article>
</BaseLayout>
