---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReportCard from '../../components/ReportCard.astro';
import { t } from '../../i18n/ui';

const lang = 'en';
const reports = (await getCollection('reports'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const grouped = new Map<string, typeof reports>();
for (const r of reports) {
  const month = r.data.dateStr.slice(0, 7);
  if (!grouped.has(month)) grouped.set(month, []);
  grouped.get(month)!.push(r);
}
---

<BaseLayout title={`${t(lang, 'archive.title')} - ${t(lang, 'site.title')}`} description={t(lang, 'archive.description')} lang={lang}>
  <h1 class="mb-2 text-2xl font-bold text-gray-900">{t(lang, 'archive.title')}</h1>
  <p class="mb-8 text-gray-500">{t(lang, 'archive.description')}</p>

  {reports.length === 0 ? (
    <p class="text-center text-gray-500 py-20">{t(lang, 'noReports')}</p>
  ) : (
    [...grouped.entries()].map(([month, items]) => (
      <section class="mb-8">
        <h2 class="mb-3 text-lg font-semibold text-gray-700 border-b border-gray-200 pb-2">{month}</h2>
        <div class="flex flex-col gap-3">
          {items.map((r) => (
            <ReportCard
              slug={r.slug}
              title={r.data.title}
              dateStr={r.data.dateStr}
              description={r.data.description}
              hasSlides={r.data.hasSlides}
              infographic={r.data.infographic}
              lang={lang}
            />
          ))}
        </div>
      </section>
    ))
  )}
</BaseLayout>
