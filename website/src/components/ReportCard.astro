---
interface Props {
  slug: string;
  title: string;
  dateStr: string;
  description: string;
  hasSlides: boolean;
  infographic?: string;
}

const { slug, title, dateStr, description, hasSlides, infographic } = Astro.props;
---

<a href={`/fin-report/reports/${slug}`}
   class="block rounded-lg border border-gray-200 bg-white p-5 transition-all hover:border-blue-300 hover:shadow-md">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <time class="text-xs font-medium text-blue-600">{dateStr}</time>
      <h3 class="mt-1 text-base font-semibold text-gray-900 truncate">{title}</h3>
      <p class="mt-1 text-sm text-gray-500 line-clamp-2">{description}</p>
    </div>
    <div class="flex gap-1.5 shrink-0">
      {infographic && (
        <span class="rounded bg-green-50 px-1.5 py-0.5 text-xs text-green-700">信息图</span>
      )}
      {hasSlides && (
        <span class="rounded bg-purple-50 px-1.5 py-0.5 text-xs text-purple-700">幻灯片</span>
      )}
    </div>
  </div>
</a>
