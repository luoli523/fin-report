---
import ReportCard from './ReportCard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  label: string;
  icon: string;
  sectorKey: string;
  reports: CollectionEntry<'reports'>[];
}

const { label, icon, sectorKey, reports } = Astro.props;

const latest = reports[0];
const recent = reports.slice(1, 5);
---

<section class="mb-12">
  {/* Sector header */}
  <div class="flex items-center justify-between mb-5 border-b border-gray-200 pb-3">
    <h2 class="text-xl font-bold text-gray-900 flex items-center gap-2">
      <span>{icon}</span>
      <span>{label}</span>
    </h2>
    <a href="/fin-report/archive" class="text-sm text-blue-600 hover:text-blue-700">
      查看全部 &rarr;
    </a>
  </div>

  {latest ? (
    <>
      {/* Compact hero: thumbnail left + info right */}
      <a
        href={`/fin-report/reports/${latest.slug}`}
        class="flex flex-col sm:flex-row gap-5 rounded-xl border border-gray-200 bg-white p-4 transition-all hover:border-blue-300 hover:shadow-md mb-5"
      >
        {latest.data.infographic && (
          <img
            src={latest.data.infographic}
            alt={latest.data.title}
            loading="lazy"
            decoding="async"
            class="w-full sm:w-[200px] sm:min-w-[200px] h-auto rounded-lg border border-gray-100 object-cover"
          />
        )}
        <div class="flex flex-col justify-center min-w-0">
          <div class="flex items-center gap-2 mb-2">
            <time class="rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-700">
              {latest.data.dateStr}
            </time>
            <span class="rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-medium text-amber-700">
              最新
            </span>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-1 line-clamp-1">{latest.data.title}</h3>
          <p class="text-sm text-gray-500 line-clamp-2 mb-3">{latest.data.description}</p>
          <span class="inline-flex items-center text-sm font-medium text-blue-600">
            阅读完整报告 &rarr;
          </span>
        </div>
      </a>

      {/* Recent reports list */}
      {recent.length > 0 && (
        <div class="flex flex-col gap-3">
          {recent.map((r) => (
            <ReportCard
              slug={r.slug}
              title={r.data.title}
              dateStr={r.data.dateStr}
              description={r.data.description}
              hasSlides={r.data.hasSlides}
              infographic={r.data.infographic}
            />
          ))}
        </div>
      )}
    </>
  ) : (
    <p class="text-center text-gray-400 py-10">该板块暂无报告</p>
  )}
</section>
