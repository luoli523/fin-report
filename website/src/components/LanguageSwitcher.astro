---
import type { Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'zh' } = Astro.props;

// Build the alternate language URL
const pathname = Astro.url.pathname;
const base = '/fin-report';

let altHref: string;
if (lang === 'zh') {
  // Current is Chinese, link to English
  const relativePath = pathname.replace(base, '') || '/';
  altHref = `${base}/en${relativePath === '/' ? '' : relativePath}`;
} else {
  // Current is English, link to Chinese
  altHref = pathname.replace(`${base}/en`, base) || base;
}

const altLabel = lang === 'zh' ? 'EN' : '中';
---

<a href={altHref}
   class="rounded border border-gray-300 px-2 py-1 text-xs font-medium text-gray-600 hover:bg-gray-100 transition-colors">
  {altLabel}
</a>
