---
const tocTitle = '目录';
const expandLabel = '展开';
const collapseLabel = '收起';
---

<!-- Reading progress bar -->
<div id="reading-progress-container" class="fixed top-0 left-0 right-0 z-50 h-0.5 bg-transparent">
  <div id="reading-progress" class="h-full bg-blue-500/70 transition-[width] duration-150 ease-out" style="width:0%"></div>
</div>

<!-- Two-column layout: TOC sidebar + content -->
<div class="lg:flex lg:gap-8 mt-6">

  <!-- Desktop TOC sidebar -->
  <nav id="toc-desktop" class="hidden lg:block lg:w-48 lg:shrink-0" aria-label={tocTitle}>
    <div class="sticky top-6">
      <h3 class="text-[11px] font-semibold uppercase tracking-widest text-gray-400 mb-3">{tocTitle}</h3>
      <ul id="toc-list"></ul>
    </div>
  </nav>

  <!-- Main content area -->
  <div id="report-content" class="prose prose-gray prose-lg max-w-none flex-1 min-w-0">
    <slot />
  </div>
</div>

<!-- Mobile TOC floating button -->
<button
  id="toc-mobile-btn"
  class="fixed bottom-6 right-6 z-40 lg:hidden w-12 h-12 rounded-full shadow-lg flex items-center justify-center bg-blue-600 text-white hover:bg-blue-700 active:scale-95 transition-all"
  aria-label={tocTitle}
>
  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
  </svg>
</button>

<!-- Mobile TOC overlay -->
<div id="toc-mobile-overlay" class="fixed inset-0 z-50 hidden lg:hidden">
  <div id="toc-mobile-backdrop" class="absolute inset-0 bg-black/40"></div>
  <div id="toc-mobile-panel" class="absolute bottom-0 left-0 right-0 bg-white rounded-t-2xl overflow-y-auto p-6" style="max-height:70vh">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold text-gray-900">{tocTitle}</h3>
      <button id="toc-mobile-close" class="p-1 text-gray-400 hover:text-gray-600 rounded-lg" aria-label="Close">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <ul id="toc-mobile-list" class="space-y-1"></ul>
  </div>
</div>

<script define:vars={{ expandLabel, collapseLabel }}>
document.addEventListener('DOMContentLoaded', () => {
  const content = document.getElementById('report-content');
  if (!content) return;

  const SECTION_MAP = [
    { match: '执行摘要',       type: 'hero',      icon: '📋' },
    { match: 'Executive',      type: 'hero',      icon: '📋' },
    { match: '市场全景',       type: 'data',      icon: '📊' },
    { match: 'Market',         type: 'data',      icon: '📊' },
    { match: '核心持仓',       type: 'holdings',  icon: '🎯' },
    { match: 'Core Holding',   type: 'holdings',  icon: '🎯' },
    { match: '今日主题',       type: 'analysis',  icon: '💡' },
    { match: 'Theme',          type: 'analysis',  icon: '💡' },
    { match: '要闻',           type: 'news',      icon: '📰' },
    { match: 'News',           type: 'news',      icon: '📰' },
    { match: '前瞻',           type: 'outlook',   icon: '📅' },
    { match: 'Week Ahead',     type: 'outlook',   icon: '📅' },
    { match: '智慧资金',       type: 'signal',    icon: '🔍' },
    { match: 'Smart Money',    type: 'signal',    icon: '🔍' },
    { match: '策略',           type: 'strategy',  icon: '⚙️' },
    { match: 'Strategy',       type: 'strategy',  icon: '⚙️' },
    { match: '附录',           type: 'appendix',  icon: '📎' },
    { match: 'Appendix',       type: 'appendix',  icon: '📎' },
    { match: '致鬼哥',         type: 'blessing',  icon: '🎊' },
    { match: 'Blessing',       type: 'blessing',  icon: '🎊' },
    { match: '免责声明',       type: 'appendix',  icon: '' },
    { match: 'Disclaimer',     type: 'appendix',  icon: '' },
  ];

  function detectType(text) {
    for (const s of SECTION_MAP) {
      if (text.includes(s.match)) return s;
    }
    return { type: 'default', icon: '' };
  }

  /* ─── 1. Section wrapping ─── */

  const children = Array.from(content.children);
  const sectionData = [];
  let current = null;

  for (const child of children) {
    if (child.tagName === 'H2') {
      current = { heading: child, elements: [], text: child.textContent.trim() };
      sectionData.push(current);
    } else if (current) {
      if (child.tagName === 'HR') continue;
      current.elements.push(child);
    }
  }

  content.innerHTML = '';

  sectionData.forEach((s, i) => {
    const info = detectType(s.text);
    const section = document.createElement('section');
    section.id = `section-${i}`;
    section.className = `report-section section-${info.type}`;
    section.setAttribute('data-type', info.type);

    if (info.icon) {
      const span = document.createElement('span');
      span.className = 'section-icon';
      span.textContent = info.icon;
      span.setAttribute('aria-hidden', 'true');
      s.heading.prepend(span);
    }

    section.appendChild(s.heading);
    s.elements.forEach(el => section.appendChild(el));
    content.appendChild(section);
  });

  /* ─── 2. Build TOC ─── */

  const tocList = document.getElementById('toc-list');
  const tocMobileList = document.getElementById('toc-mobile-list');

  sectionData.forEach((s, i) => {
    const info = detectType(s.text);
    const label = s.text.replace(/^[📋📊🎯💡📰📅🔍⚙️📎🎊]\s*/, '');

    if (tocList) {
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = `#section-${i}`;
      a.className = 'toc-link';
      a.dataset.idx = String(i);
      a.textContent = label;
      li.appendChild(a);
      tocList.appendChild(li);
    }

    if (tocMobileList) {
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = `#section-${i}`;
      a.className = 'toc-mobile-link';
      a.dataset.idx = String(i);
      a.innerHTML = `${info.icon ? info.icon + ' ' : ''}${label}`;
      a.addEventListener('click', () => closeMobileTOC());
      li.appendChild(a);
      tocMobileList.appendChild(li);
    }
  });

  /* ─── 3. Active section highlight (Intersection Observer) ─── */

  const allSections = content.querySelectorAll('.report-section');
  let currentActive = null;

  const observer = new IntersectionObserver(entries => {
    for (const entry of entries) {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        if (id === currentActive) continue;
        currentActive = id;

        document.querySelectorAll('.toc-link, .toc-mobile-link').forEach(link => {
          link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
        });
      }
    }
  }, { rootMargin: '-5% 0px -75% 0px', threshold: 0 });

  allSections.forEach(s => observer.observe(s));

  /* ─── 4. Holdings table → card grid ─── */

  const holdingsSection = content.querySelector('.section-holdings');
  if (holdingsSection) {
    const table = holdingsSection.querySelector('table');
    if (table) {
      const rows = table.querySelectorAll('tbody tr');
      if (rows.length > 0 && rows.length <= 6) {
        const grid = document.createElement('div');
        grid.className = 'holdings-grid not-prose';

        rows.forEach(row => {
          const cells = Array.from(row.querySelectorAll('td'));
          if (cells.length < 3) return;

          const ticker = (cells[0].textContent || '').replace(/\*/g, '').trim();
          const status = (cells[1].textContent || '').trim();
          const signal = (cells[2].textContent || '').trim();
          const keyPoint = cells[3] ? (cells[3].textContent || '').trim() : '';

          const isBuy = /加仓|Buy/i.test(signal);
          const isSell = /减仓|Sell|Reduce/i.test(signal);
          const signalClass = isBuy ? 'buy' : isSell ? 'sell' : 'hold';
          const signalText = signal.replace(/[⚪🟢🔴]\s*/, '');

          const card = document.createElement('div');
          card.className = `holding-card signal-${signalClass}`;
          card.innerHTML = `
            <div class="flex items-center justify-between">
              <span class="holding-ticker">${ticker}</span>
              <span class="holding-signal-badge ${signalClass}">${signalText}</span>
            </div>
            <div class="holding-status">${status}</div>
            ${keyPoint ? `<div class="holding-keypoint">💡 ${keyPoint}</div>` : ''}
          `;
          grid.appendChild(card);
        });

        table.replaceWith(grid);
      }
    }
  }

  /* ─── 5. Appendix collapse ─── */

  content.querySelectorAll('.section-appendix').forEach(section => {
    const h2 = section.querySelector('h2');
    if (!h2) return;

    const bodyEls = Array.from(section.children).filter(el => el !== h2);
    const wrapper = document.createElement('div');
    wrapper.className = 'appendix-body collapsed';
    bodyEls.forEach(el => wrapper.appendChild(el));
    section.appendChild(wrapper);

    const btn = document.createElement('button');
    btn.className = 'appendix-toggle';
    btn.innerHTML = `${expandLabel} <svg class="w-3 h-3 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>`;
    h2.after(btn);

    btn.addEventListener('click', () => {
      const isCollapsed = wrapper.classList.contains('collapsed');
      wrapper.classList.toggle('collapsed', !isCollapsed);
      wrapper.classList.toggle('expanded', isCollapsed);
      btn.innerHTML = isCollapsed
        ? `${collapseLabel} <svg class="w-3 h-3 rotate-180 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>`
        : `${expandLabel} <svg class="w-3 h-3 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>`;
    });
  });

  /* ─── 6. Reading progress bar ─── */

  const progressBar = document.getElementById('reading-progress');
  if (progressBar) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrollY = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          progressBar.style.width = docHeight > 0 ? `${(scrollY / docHeight) * 100}%` : '0%';
          ticking = false;
        });
        ticking = true;
      }
    });
  }

  /* ─── 7. Mobile TOC ─── */

  const overlay = document.getElementById('toc-mobile-overlay');
  const openBtn = document.getElementById('toc-mobile-btn');
  const closeBtn = document.getElementById('toc-mobile-close');
  const backdrop = document.getElementById('toc-mobile-backdrop');

  function openMobileTOC() {
    if (overlay) {
      overlay.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
  }

  function closeMobileTOC() {
    if (overlay) {
      overlay.classList.add('hidden');
      document.body.style.overflow = '';
    }
  }

  if (openBtn)  openBtn.addEventListener('click', openMobileTOC);
  if (closeBtn) closeBtn.addEventListener('click', closeMobileTOC);
  if (backdrop) backdrop.addEventListener('click', closeMobileTOC);

  /* ─── 8. Text visual enhancements ─── */

  const SKIP_TAGS = new Set(['CODE','PRE','SCRIPT','STYLE','TEXTAREA','INPUT']);
  const NON_TICKERS = new Set([
    'AI','IT','ETF','CEO','SEC','USD','EUR','GBP','JPY','CNY','CHF','SGD',
    'TOP','RSS','EDA','GPU','CPU','LLM','API','FAQ','PDF','IPO','ESG',
    'GDP','CPI','PPI','PMI','NFP','PCE','YOY','QOQ','MOM','BPS','UTC',
    'THE','AND','FOR','NOT','ALL','HAS','BUT','ITS','ARE','WAS','HAD',
    'MAY','CAN','RUN','USE','NEW','ANY','LET','YET','HOW','WHO','NOW',
    'DID','SET','GET','PUT','ADD','END','SAY','OLD','OUR','TRY','OWN',
    'CAP','NET','LOW','HIGH','AVG','MAX','MIN','RAW','KEY','BUY','DAY',
  ]);

  function getTextNodes(root) {
    const nodes = [];
    const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
    while (walker.nextNode()) {
      const n = walker.currentNode;
      if (!n.textContent.trim()) continue;
      let p = n.parentElement, ok = true;
      while (p && p !== root) {
        if (SKIP_TAGS.has(p.tagName) || p.hasAttribute('data-enh')) { ok = false; break; }
        p = p.parentElement;
      }
      if (ok) nodes.push(n);
    }
    return nodes;
  }

  function replaceInTextNode(node, regex, replacer) {
    const text = node.textContent;
    regex.lastIndex = 0;
    if (!regex.test(text)) return;
    regex.lastIndex = 0;
    const frag = document.createDocumentFragment();
    let last = 0, m;
    while ((m = regex.exec(text)) !== null) {
      if (m.index > last) frag.appendChild(document.createTextNode(text.slice(last, m.index)));
      const el = replacer(m);
      frag.appendChild(el || document.createTextNode(m[0]));
      last = regex.lastIndex;
    }
    if (last < text.length) frag.appendChild(document.createTextNode(text.slice(last)));
    node.parentNode.replaceChild(frag, node);
  }

  // 8a. Risk alert blockquotes
  content.querySelectorAll('blockquote').forEach(bq => {
    if (/风险警示|Risk Alert|⚠️/.test(bq.textContent)) {
      bq.classList.add('risk-alert');
    }
  });

  // 8b. Top5 up/down bars
  content.querySelectorAll('p').forEach(p => {
    const t = p.textContent;
    if (/🟢.*涨/.test(t)) p.classList.add('top5-up');
    else if (/🔴.*跌/.test(t)) p.classList.add('top5-down');
  });

  // 8c. Advice / tracking highlight blocks
  content.querySelectorAll('p').forEach(p => {
    const t = p.textContent.trim();
    if (t.startsWith('操作建议')) p.classList.add('advice-block');
    else if (t.startsWith('跟踪指标')) p.classList.add('tracking-block');
  });

  // 8d. Action checklist
  content.querySelectorAll('h3').forEach(h3 => {
    if (/行动清单|Action/.test(h3.textContent)) {
      const next = h3.nextElementSibling;
      if (next && (next.tagName === 'UL' || next.tagName === 'OL')) {
        next.classList.add('action-checklist');
      }
    }
  });

  // 8e. Percentage coloring (all sections, including tables)
  const pctRe = /([+\-]\d+\.?\d*%)/g;
  content.querySelectorAll('.report-section').forEach(section => {
    getTextNodes(section).forEach(node => {
      replaceInTextNode(node, pctRe, (m) => {
        const span = document.createElement('span');
        span.className = m[1].startsWith('-') ? 'pct-down' : 'pct-up';
        span.textContent = m[1];
        span.setAttribute('data-enh', '1');
        return span;
      });
    });
  });

  // 8f. Ticker highlighting (paragraphs & list items, skip appendix & tables)
  const tickRe = /\b([A-Z]{3,5})\b/g;
  content.querySelectorAll('.report-section:not(.section-appendix)').forEach(section => {
    section.querySelectorAll('p, li').forEach(el => {
      getTextNodes(el).forEach(node => {
        replaceInTextNode(node, tickRe, (m) => {
          if (NON_TICKERS.has(m[1])) return null;
          const span = document.createElement('span');
          span.className = 'ticker-pill';
          span.textContent = m[1];
          span.setAttribute('data-enh', '1');
          return span;
        });
      });
    });
  });
});
</script>
