---
interface Props {
  dateStr: string;
  count: number;
}

const { dateStr, count } = Astro.props;
const padLen = count >= 100 ? 3 : 2;
const slides = Array.from({ length: count }, (_, i) => {
  const num = String(i + 1).padStart(padLen, '0');
  return `/fin-report/images/slides/${dateStr}/slide-${num}.webp`;
});
const galleryId = `gallery-${dateStr}`;
const lightboxId = `lb-${dateStr}`;
const slidesJson = JSON.stringify(slides);
---

<section class="my-8">
  <h2 class="mb-4 text-xl font-bold text-gray-900">幻灯片</h2>

  <div class="relative rounded-lg border border-gray-200 bg-white overflow-hidden" id={galleryId}>
    <div class="absolute top-3 right-3 z-10 flex gap-2">
      <button
        onclick={`document.getElementById('${lightboxId}').showModal()`}
        class="flex items-center gap-1 rounded-full bg-black/50 px-3 py-1 text-xs text-white hover:bg-black/70 transition-colors cursor-pointer"
        title="点击放大"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v6m3-3H7" />
        </svg>
        放大
      </button>
      <span class="rounded-full bg-black/50 px-3 py-1 text-xs text-white">
        <span data-current>1</span> / {count}
      </span>
    </div>

    <div class="overflow-hidden">
      <div class="flex overflow-x-auto snap-x snap-mandatory scrollbar-hide" data-track>
        {slides.map((src, i) => (
          <div class="w-full flex-none snap-start" data-index={i}>
            <img
              src={src}
              alt={`Slide ${i + 1}`}
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding="async"
              class="w-full h-auto cursor-zoom-in"
              onclick={`window._openSlide&&window._openSlide('${lightboxId}',${i})`}
            />
          </div>
        ))}
      </div>
    </div>

    <button
      data-prev
      class="absolute left-2 top-1/2 -translate-y-1/2 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-black/40 text-white text-2xl hover:bg-black/60 transition-colors"
      aria-label="Previous"
    >&lsaquo;</button>
    <button
      data-next
      class="absolute right-2 top-1/2 -translate-y-1/2 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-black/40 text-white text-2xl hover:bg-black/60 transition-colors"
      aria-label="Next"
    >&rsaquo;</button>
  </div>

  <div class="mt-3 flex gap-1.5 overflow-x-auto pb-2" data-thumbs>
    {slides.map((src, i) => (
      <button
        class:list={[
          'flex-none rounded border-2 overflow-hidden transition-all opacity-50 hover:opacity-80',
          i === 0 ? 'border-blue-500 opacity-100' : 'border-transparent',
        ]}
        data-thumb={i}
      >
        <img src={src} alt={`Thumb ${i + 1}`} loading="lazy" decoding="async" class="h-12 w-auto" />
      </button>
    ))}
  </div>
</section>

<!-- Lightbox -->
<dialog
  id={lightboxId}
  class="slide-lightbox"
  onclick="if(event.target===this)this.close()"
  data-slides={slidesJson}
  data-count={count}
>
  <div class="slide-lightbox-inner">
    <button class="lb-close" onclick="this.closest('dialog').close()" aria-label="Close">&times;</button>
    <div class="lb-counter"><span data-lb-current>1</span> / {count}</div>
    <button class="lb-arrow lb-arrow-left" data-lb-prev aria-label="Previous">&lsaquo;</button>
    <img data-lb-img src={slides[0]} alt="Slide" class="lb-img" />
    <button class="lb-arrow lb-arrow-right" data-lb-next aria-label="Next">&rsaquo;</button>
  </div>
</dialog>

<script define:vars={{ galleryId, lightboxId, count }}>
  // Register global helper for inline onclick on images
  window._openSlide = function(lbId, index) {
    const lb = document.getElementById(lbId);
    if (!lb) return;
    const slides = JSON.parse(lb.dataset.slides);
    lb._current = index;
    lb.querySelector('[data-lb-img]').src = slides[index];
    lb.querySelector('[data-lb-current]').textContent = String(index + 1);
    lb.showModal();
  };

  const root = document.getElementById(galleryId);
  const lb = document.getElementById(lightboxId);

  if (root && lb) {
    const track = root.querySelector('[data-track]');
    const counter = root.querySelector('[data-current]');
    const prevBtn = root.querySelector('[data-prev]');
    const nextBtn = root.querySelector('[data-next]');
    const thumbs = root.parentElement.querySelectorAll('[data-thumb]');
    const lbImg = lb.querySelector('[data-lb-img]');
    const lbCounter = lb.querySelector('[data-lb-current]');
    const allSlides = JSON.parse(lb.dataset.slides);
    let current = 0;
    lb._current = 0;

    function updateThumbs() {
      thumbs.forEach((t, i) => {
        t.classList.toggle('border-blue-500', i === current);
        t.classList.toggle('border-transparent', i !== current);
        t.classList.toggle('opacity-100', i === current);
        t.classList.toggle('opacity-50', i !== current);
      });
    }

    function goTo(idx) {
      current = Math.max(0, Math.min(count - 1, idx));
      track.children[current].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
      counter.textContent = String(current + 1);
      updateThumbs();
    }

    function lbGoTo(idx) {
      current = Math.max(0, Math.min(count - 1, idx));
      lb._current = current;
      lbImg.src = allSlides[current];
      lbCounter.textContent = String(current + 1);
      counter.textContent = String(current + 1);
      track.children[current].scrollIntoView({ block: 'nearest', inline: 'start' });
      updateThumbs();
    }

    // Gallery nav
    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));
    thumbs.forEach((t) => t.addEventListener('click', () => goTo(Number(t.dataset.thumb))));

    // Lightbox nav
    lb.querySelector('[data-lb-prev]').addEventListener('click', (e) => { e.stopPropagation(); lbGoTo(current - 1); });
    lb.querySelector('[data-lb-next]').addEventListener('click', (e) => { e.stopPropagation(); lbGoTo(current + 1); });

    // Sync current index when lightbox opens via zoom button
    lb.addEventListener('open', () => { lb._current = current; });

    // Keep gallery current in sync when opened from inline onclick
    const observer = new MutationObserver(() => {
      if (lb.open && lb._current !== undefined) {
        current = lb._current;
      }
    });
    observer.observe(lb, { attributes: true });

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (lb.open) {
        if (e.key === 'ArrowLeft') { e.preventDefault(); lbGoTo(current - 1); }
        else if (e.key === 'ArrowRight') { e.preventDefault(); lbGoTo(current + 1); }
      } else {
        if (e.key === 'ArrowLeft') goTo(current - 1);
        if (e.key === 'ArrowRight') goTo(current + 1);
      }
    });

    // Sync zoom button to open with current slide
    root.querySelector('[title="点击放大"]').addEventListener('click', () => {
      lbImg.src = allSlides[current];
      lbCounter.textContent = String(current + 1);
    });
  }
</script>

<style>
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  .scrollbar-hide::-webkit-scrollbar { display: none; }

  .slide-lightbox {
    position: fixed; inset: 0; z-index: 50;
    max-width: none; max-height: none; width: 100vw; height: 100vh;
    margin: 0; padding: 0;
    background: rgba(0,0,0,0.92);
    border: none;
  }
  .slide-lightbox::backdrop { background: transparent; }
  .slide-lightbox[open] { animation: lb-fade 0.15s ease-out; }
  @keyframes lb-fade { from { opacity: 0; } to { opacity: 1; } }

  .slide-lightbox-inner {
    position: relative; display: flex;
    align-items: center; justify-content: center;
    width: 100%; height: 100%;
    user-select: none;
  }
  .lb-close {
    position: absolute; top: 1rem; right: 1rem; z-index: 20;
    display: flex; align-items: center; justify-content: center;
    width: 2.5rem; height: 2.5rem;
    border-radius: 9999px; border: none;
    background: rgba(255,255,255,0.2); color: white;
    font-size: 1.5rem; cursor: pointer;
    transition: background 0.2s;
  }
  .lb-close:hover { background: rgba(255,255,255,0.4); }
  .lb-counter {
    position: absolute; top: 1rem; left: 50%; transform: translateX(-50%); z-index: 20;
    border-radius: 9999px; padding: 0.375rem 1rem;
    background: rgba(255,255,255,0.2); color: white; font-size: 0.875rem;
  }
  .lb-arrow {
    position: absolute; top: 50%; transform: translateY(-50%); z-index: 20;
    display: flex; align-items: center; justify-content: center;
    width: 3rem; height: 3rem;
    border-radius: 9999px; border: none;
    background: rgba(255,255,255,0.2); color: white;
    font-size: 1.75rem; cursor: pointer;
    transition: background 0.2s;
  }
  .lb-arrow:hover { background: rgba(255,255,255,0.4); }
  .lb-arrow-left { left: 1rem; }
  .lb-arrow-right { right: 1rem; }
  .lb-img { max-width: 92vw; max-height: 88vh; object-fit: contain; border-radius: 0.25rem; }
</style>
